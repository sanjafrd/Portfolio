---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { ProjectImageLightbox } from '../components/react/ProjectImageLightbox';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  subtitle?: string;
  category: string;
  description?: string;
  cover?: ImageMetadata;
  wide?: boolean;
}

const { title, subtitle, category, description, cover, wide = false } = Astro.props;

const ogImage = cover
  ? await getImage({ src: cover, width: 1200, height: 630, format: 'jpeg', quality: 80 })
  : undefined;
---

<BaseLayout
  title={`${title} — Sanjali Frédélisy`}
  description={description ?? subtitle ?? `${title} — projet réalisé par Sanjali Frédélisy.`}
  image={ogImage?.src}
>
  <section
    class="min-h-screen bg-gradient-to-br from-[#f0e7d7] via-[#f9e0da]/30 to-[#f0e7d7] px-4 py-32 md:px-8"
  >
    <div class:list={['mx-auto', wide ? 'max-w-7xl' : 'max-w-5xl']}>
      <a
        href="/realisations"
        data-smart-back
        class="group mb-12 inline-flex items-center gap-3 text-[#8c5b45] transition-colors hover:text-[#5c2c1f]"
      >
        <span
          class="flex h-9 w-9 items-center justify-center rounded-full bg-[#5c2c1f]/5 transition-colors group-hover:bg-[#5c2c1f]/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M19 12H5" />
            <path d="M12 19l-7-7 7-7" />
          </svg>
        </span>
        <span class="font-medium text-sm uppercase tracking-widest"
          >Retour aux réalisations</span
        >
      </a>

      <header class="mb-16">
        <span
          class="mb-6 inline-block rounded-full border border-[#702a0c]/20 bg-[#702a0c]/5 px-4 py-1.5 text-[#8c5b45] text-xs font-medium uppercase tracking-widest backdrop-blur-sm"
        >
          {category}
        </span>
        <h1
          class="mb-6 font-serif text-5xl text-[#5c2c1f] leading-tight md:text-7xl"
        >
          {title}
        </h1>
        {
          subtitle && (
            <p class="font-light text-[#8c5b45] text-xl italic md:text-2xl">
              {subtitle}
            </p>
          )
        }
      </header>

      <slot />

      <footer class="mt-32 flex justify-center border-[#5c2c1f]/10 border-t pt-16">
        <a
          href="/realisations"
          data-smart-back
          class="group inline-flex items-center gap-3 rounded-full bg-[#702a0c] px-10 py-4 font-medium text-[#f0e7d7] shadow-lg transition-all duration-300 hover:scale-105 hover:bg-[#5c2c1f] hover:shadow-[#702a0c]/20 hover:shadow-xl"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="transition-transform group-hover:-translate-x-1"
          >
            <path d="M19 12H5" />
            <path d="M12 19l-7-7 7-7" />
          </svg>
          Voir les autres projets
        </a>
      </footer>
    </div>
  </section>
  <ProjectImageLightbox client:idle />

  <script>
    function setupSmartBack() {
      const links = document.querySelectorAll<HTMLAnchorElement>('a[data-smart-back]');
      links.forEach((link) => {
        if (link.dataset.smartBackBound === 'true') return;
        link.dataset.smartBackBound = 'true';
        link.addEventListener('click', (event) => {
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          const previous = sessionStorage.getItem('portfolio-previous-path') ?? '';
          if (previous.startsWith('/realisations')) {
            event.preventDefault();
            window.history.back();
          }
        });
      });
    }

    setupSmartBack();
    document.addEventListener('astro:page-load', setupSmartBack);
  </script>
</BaseLayout>
