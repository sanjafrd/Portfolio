---
import { type CollectionEntry, getCollection } from 'astro:content';
import FormattedText from '../../components/astro/FormattedText.astro';
import Gallery from '../../components/astro/Gallery.astro';
import Hero from '../../components/astro/Hero.astro';
import ProjectSections from '../../components/astro/ProjectSections.astro';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data } = project;

const sections: { title: string; content: string | undefined }[] = [
  { title: 'Contexte', content: data.details?.context },
];

const afterSections: { title: string; content: string | undefined }[] = [
  { title: 'Veille', content: data.details?.watch },
  { title: 'Stratégie', content: data.details?.strategy },
  { title: 'Création', content: data.details?.creation },
  { title: 'Diffusion', content: data.details?.diffusion },
  { title: 'Analyse', content: data.details?.analysis },
];

const hasStructuredSections =
  (data.targetTabs && data.targetTabs.length > 0) ||
  (data.objectives && data.objectives.length > 0) ||
  !!data.simpleObjectives;

const fallbackTarget = !hasStructuredSections
  ? { title: 'Publics visés', content: data.details?.target }
  : null;
---

<ProjectLayout
  title={data.title}
  subtitle={data.subtitle}
  category={data.category}
  description={data.description}
  cover={data.cover}
  wide={!!data.detailRightImage}
>
  <Hero
    title={data.title}
    slug={project.id}
    cover={data.cover}
    carouselImages={data.carouselImages}
    videoUrl={data.videoUrl}
    videoUrls={data.videoUrls}
    detailImages={data.detailImages}
    detailImagesTop={data.detailImagesTop}
    detailImagesBottom={data.detailImagesBottom}
    detailRightImage={data.detailRightImage}
    banner={data.banner}
    specialLayout={data.specialLayout}
  />

  <div class="mx-auto max-w-4xl">
    {
      sections.map(
        ({ title, content }) =>
          content && (
            <section class="mb-16">
              <h2 class="mb-8 inline-block border-[#702a0c]/30 border-b-2 pr-12 pb-4 font-serif font-bold text-3xl text-[#5c2c1f] md:text-4xl">
                {title}
              </h2>
              <FormattedText content={content} />
            </section>
          ),
      )
    }

    {
      fallbackTarget?.content && (
        <section class="mb-16">
          <h2 class="mb-8 inline-block border-[#702a0c]/30 border-b-2 pr-12 pb-4 font-serif font-bold text-3xl text-[#5c2c1f] md:text-4xl">
            {fallbackTarget.title}
          </h2>
          <FormattedText content={fallbackTarget.content} />
        </section>
      )
    }

    <ProjectSections
      layoutId={project.id}
      targetTabs={data.targetTabs}
      objectives={data.objectives}
      simpleObjectives={data.simpleObjectives}
    />

    {
      afterSections.map(
        ({ title, content }) =>
          content && (
            <section class="mb-16">
              <h2 class="mb-8 inline-block border-[#702a0c]/30 border-b-2 pr-12 pb-4 font-serif font-bold text-3xl text-[#5c2c1f] md:text-4xl">
                {title}
              </h2>
              <FormattedText content={content} />
            </section>
          ),
      )
    }
  </div>

  {
    data.gallery && (
      <Gallery
        title={data.title}
        config={data.gallery}
        carouselImages={data.carouselImages}
        detailImages={data.detailImages}
        detailImagesTop={data.detailImagesTop}
        detailImagesBottom={data.detailImagesBottom}
        galleryImages={data.galleryImages}
        videoUrl={data.videoUrl}
        videoUrls={data.videoUrls}
        specialLayout={data.specialLayout}
      />
    )
  }

  {
    data.externalLinks && data.externalLinks.length > 0 && (
      <div class="mx-auto mt-20 flex max-w-5xl flex-wrap justify-center gap-4">
        {data.externalLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 rounded-full border-2 border-[#702a0c] bg-transparent px-10 py-4 font-medium text-[#702a0c] transition-all duration-300 hover:scale-105 hover:bg-[#702a0c] hover:text-[#f0e7d7] hover:shadow-[#702a0c]/20 hover:shadow-xl"
          >
            {link.label}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="transition-transform group-hover:translate-x-1"
            >
              <path d="M7 17L17 7" />
              <path d="M7 7h10v10" />
            </svg>
          </a>
        ))}
      </div>
    )
  }
</ProjectLayout>
