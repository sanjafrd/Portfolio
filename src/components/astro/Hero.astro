---
import { getImage, Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { ImageSwitcher } from '../react/ImageSwitcher';
import { ProjectCarousel } from '../react/ProjectCarousel';

interface Props {
  title: string;
  slug: string;
  cover: ImageMetadata;
  carouselImages?: ImageMetadata[];
  videoUrl?: string;
  videoUrls?: string[];
  detailImages?: ImageMetadata[];
  detailImagesTop?: ImageMetadata[];
  detailImagesBottom?: ImageMetadata[];
  detailRightImage?: ImageMetadata;
  banner?: { objectPosition: string; fullBleed?: boolean };
  specialLayout?: 'benetton' | 'storyboard' | 'kakemono' | 'cem';
}

const {
  title,
  slug,
  cover,
  carouselImages,
  videoUrl,
  videoUrls,
  detailImages,
  detailImagesTop,
  detailImagesBottom,
  detailRightImage,
  banner,
  specialLayout,
} = Astro.props;

const heroTransitionName = `project-hero-${slug}`;

const isBanner = !!banner;
const isKakemono = specialLayout === 'kakemono';
const bannerImage = isKakemono ? undefined : carouselImages?.[0];

const hasSplitImages = detailImagesTop && detailImagesBottom && !isKakemono;
const hasDetailImages =
  detailImages && detailImages.length > 1 && !isBanner && specialLayout !== 'benetton';
const hasSingleDetail = detailImages && detailImages.length === 1;
const hasSideBySide = hasDetailImages || (hasSingleDetail && !!detailRightImage);

const isCEM = specialLayout === 'cem';

async function optimizeMany(metas: ImageMetadata[], width: number): Promise<string[]> {
  const results = await Promise.all(
    metas.map(async (meta) => {
      const optimized = await getImage({ src: meta, width, format: 'webp' });
      return optimized.src;
    }),
  );
  return results;
}

const carouselSrcs = carouselImages ? await optimizeMany(carouselImages, 1800) : [];
const detailSrcs = detailImages ? await optimizeMany(detailImages, 1400) : [];
const detailTopSrcs = detailImagesTop ? await optimizeMany(detailImagesTop, 1200) : [];
const detailBottomSrcs = detailImagesBottom ? await optimizeMany(detailImagesBottom, 1200) : [];
---

{
  isBanner && banner && (bannerImage || isKakemono) && (
    <div
      class:list={[
        'mb-24 aspect-video overflow-hidden md:aspect-[21/9]',
        banner.fullBleed
          ? 'relative left-1/2 right-1/2 -mx-[50vw] w-screen'
          : 'w-full rounded-3xl shadow-2xl ring-1 ring-[#5c2c1f]/10',
      ]}
    >
      {isKakemono ? (
        <Image
          src={cover}
          alt={title}
          widths={[800, 1200, 1800]}
          sizes="(min-width: 768px) 80vw, 100vw"
          class={`h-full w-full cursor-zoom-in ${banner.objectPosition}`}
          loading="eager"
          transition:name={heroTransitionName}
          data-zoomable
        />
      ) : (
        <Image
          src={bannerImage!}
          alt={title}
          widths={[800, 1200, 1800]}
          sizes="(min-width: 768px) 80vw, 100vw"
          class={`h-full w-full cursor-zoom-in ${banner.objectPosition}`}
          loading="eager"
          transition:name={heroTransitionName}
          data-zoomable
        />
      )}
    </div>
  )
}

{
  !isBanner && isCEM && videoUrl && (
    <div class="mb-24 w-full overflow-hidden rounded-3xl bg-[#5c2c1f]/5 shadow-2xl ring-1 ring-[#5c2c1f]/10">
      <div class="relative aspect-video w-full">
        <iframe
          src={videoUrl}
          class="absolute top-0 left-0 h-full w-full"
          allow="autoplay; fullscreen"
          title={title}
          style="border: none;"
        />
      </div>
    </div>
  )
}

{
  !isBanner && !isCEM && hasSplitImages && (
    <div class="mx-auto mb-24 max-w-5xl">
      <div class="flex flex-col gap-4 md:flex-row">
        <div class="w-full md:w-1/2">
          <ImageSwitcher client:load images={detailTopSrcs} alt={`${title} — Groupe 1`} />
        </div>
        <div class="w-full md:w-1/2">
          <ImageSwitcher client:load images={detailBottomSrcs} alt={`${title} — Groupe 2`} />
        </div>
      </div>
    </div>
  )
}

{
  !isBanner && !isCEM && !hasSplitImages && hasSideBySide && (
    <div
      class:list={[
        'mx-auto mb-24 flex flex-col items-start gap-8 md:flex-row',
        detailRightImage ? 'max-w-7xl' : 'max-w-5xl',
      ]}
    >
      <div class={detailRightImage ? 'w-full md:w-[55%]' : 'w-full md:w-1/2'}>
        <ImageSwitcher client:load images={detailSrcs} alt={title} />
      </div>

      {
        videoUrls && videoUrls.length > 0 ? (
          <div class="flex w-full flex-col gap-4 md:w-1/2">
            {videoUrls.map((url, index) => (
              <div class="relative aspect-video w-full overflow-hidden rounded-2xl bg-transparent">
                <iframe
                  src={url}
                  class="absolute top-0 left-0 h-full w-full"
                  allow="autoplay; fullscreen"
                  allowfullscreen
                  title={`${title} — Vidéo ${index + 1}`}
                  style="border: none; background: transparent;"
                />
              </div>
            ))}
          </div>
        ) : videoUrl ? (
          <div class="w-full md:w-1/2">
            <div class="relative aspect-video w-full overflow-hidden rounded-2xl">
              <iframe
                src={videoUrl}
                class="absolute top-0 left-0 h-full w-full"
                allow="autoplay; fullscreen"
                allowfullscreen
                title={title}
                style="border: none;"
              />
            </div>
          </div>
        ) : detailRightImage ? (
          <div class="custom-scrollbar max-h-[80vh] w-full overflow-y-auto rounded-2xl md:w-[45%]">
            <Image
              src={detailRightImage}
              alt={`${title} — Détail`}
              widths={[600, 900, 1200]}
              sizes="(min-width: 768px) 45vw, 100vw"
              class="w-full cursor-zoom-in rounded-2xl object-cover"
              data-zoomable
            />
          </div>
        ) : null
      }
    </div>
  )
}

{
  !isBanner && !isCEM && !hasSplitImages && !hasSideBySide && hasSingleDetail && detailImages && (
    <div class="mb-24 flex justify-center">
      <Image
        src={detailImages[0]}
        alt={title}
        widths={[800, 1200, 1600]}
        sizes="(min-width: 768px) 80vw, 100vw"
        class="max-h-[80vh] max-w-full cursor-zoom-in rounded-3xl object-contain shadow-2xl ring-1 ring-[#5c2c1f]/10"
        transition:name={heroTransitionName}
        data-zoomable
      />
    </div>
  )
}

{
  !isBanner &&
    !isCEM &&
    !hasSplitImages &&
    !hasSideBySide &&
    !hasSingleDetail &&
    carouselSrcs.length > 0 && (
      <div class="mb-24 w-full overflow-hidden rounded-3xl bg-[#5c2c1f]/5 shadow-2xl ring-1 ring-[#5c2c1f]/10">
        <ProjectCarousel
          client:load
          images={carouselSrcs}
          alt={title}
          videoUrl={videoUrl}
          videoUrls={videoUrls}
          aspectRatio="aspect-video md:aspect-[21/9]"
        />
      </div>
    )
}

{
  !isBanner &&
    !isCEM &&
    !hasSplitImages &&
    !hasSideBySide &&
    !hasSingleDetail &&
    carouselSrcs.length === 0 && (
      <div class="mb-24 w-full overflow-hidden rounded-3xl bg-[#5c2c1f]/5 shadow-2xl ring-1 ring-[#5c2c1f]/10">
        <div class="relative aspect-video w-full md:aspect-[21/9]">
          <Image
            src={cover}
            alt={title}
            widths={[800, 1200, 1800]}
            sizes="(min-width: 768px) 80vw, 100vw"
            class="h-full w-full cursor-zoom-in object-cover"
            loading="eager"
            transition:name={heroTransitionName}
            data-zoomable
          />
        </div>
      </div>
    )
}
