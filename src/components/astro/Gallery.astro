---
import { getImage, Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { ImageSwitcher } from '../react/ImageSwitcher';

interface GalleryConfig {
  source: 'carousel' | 'detail';
  skipFirst?: boolean;
  gridCols?: string;
  imageAspect?: 'square' | 'auto';
  itemBg?: string;
  showVideo?: boolean;
  showVideoUrls?: boolean;
}

interface Props {
  title: string;
  config: GalleryConfig;
  carouselImages?: ImageMetadata[];
  detailImages?: ImageMetadata[];
  detailImagesTop?: ImageMetadata[];
  detailImagesBottom?: ImageMetadata[];
  galleryImages?: ImageMetadata[];
  videoUrl?: string;
  videoUrls?: string[];
  specialLayout?: 'benetton' | 'storyboard' | 'kakemono' | 'cem';
}

const {
  title,
  config,
  carouselImages,
  detailImages,
  detailImagesTop,
  detailImagesBottom,
  galleryImages,
  videoUrl,
  videoUrls,
  specialLayout,
} = Astro.props;

const isKakemono = specialLayout === 'kakemono';

const rawImages =
  galleryImages && galleryImages.length > 0
    ? galleryImages
    : config.source === 'carousel'
      ? carouselImages
      : detailImages;
const images = rawImages ? (config.skipFirst ? rawImages.slice(1) : rawImages) : [];

const gridCols = config.gridCols ?? 'grid-cols-2 md:grid-cols-3';
const itemClasses = `overflow-hidden rounded-2xl ring-1 ring-[#5c2c1f]/10 shadow-lg ${config.itemBg ?? ''}`;
const imgClasses =
  config.imageAspect === 'auto'
    ? 'h-auto w-full cursor-zoom-in object-contain'
    : 'aspect-square h-full w-full cursor-zoom-in object-cover';

const hasVideos = config.showVideo || config.showVideoUrls;

async function optimizeMany(metas: ImageMetadata[], width: number): Promise<string[]> {
  return Promise.all(
    metas.map(async (meta) => {
      const optimized = await getImage({ src: meta, width, format: 'webp' });
      return optimized.src;
    }),
  );
}

const kakemonoTopSrcs =
  isKakemono && detailImagesTop ? await optimizeMany(detailImagesTop, 1200) : [];
const kakemonoBottomSrcs =
  isKakemono && detailImagesBottom ? await optimizeMany(detailImagesBottom, 1200) : [];
---

<section class="mx-auto mt-24 max-w-5xl">
  <h2
    class="mb-12 inline-block border-[#702a0c]/30 border-b-2 pr-12 pb-4 font-serif text-3xl text-[#5c2c1f] md:text-4xl"
  >
    Galerie
  </h2>

  {
    isKakemono && detailImagesTop && detailImagesBottom ? (
      <div class="flex w-full flex-col gap-4 md:flex-row">
        <div class="w-full md:w-1/2">
          <ImageSwitcher client:load images={kakemonoTopSrcs} alt={`${title} — Groupe 1`} />
        </div>
        <div class="w-full md:w-1/2">
          <ImageSwitcher client:load images={kakemonoBottomSrcs} alt={`${title} — Groupe 2`} />
        </div>
      </div>
    ) : images.length > 0 ? (
      <div class="w-full">
        <div class:list={['grid gap-4', gridCols, hasVideos ? 'mb-8' : '']}>
          {images.map((image, index) => (
            <div class={itemClasses}>
              <Image
                src={image}
                alt={`${title} — Image ${index + 1}`}
                widths={[400, 600, 900]}
                sizes="(min-width: 768px) 33vw, 50vw"
                class={imgClasses}
                loading="lazy"
                data-zoomable
              />
            </div>
          ))}
        </div>

        {config.showVideo && videoUrl && (
          <div class="w-full overflow-hidden rounded-2xl shadow-lg ring-1 ring-[#5c2c1f]/10">
            <div class="relative aspect-video w-full">
              <iframe
                src={videoUrl}
                class="absolute top-0 left-0 h-full w-full"
                allow="autoplay; fullscreen"
                allowfullscreen
                title={title}
                style="border: none;"
              />
            </div>
          </div>
        )}

        {config.showVideoUrls && videoUrls && videoUrls.length > 0 && (
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            {videoUrls.map((url, index) => (
              <div class="w-full overflow-hidden rounded-2xl shadow-lg ring-1 ring-[#5c2c1f]/10">
                <div class="relative aspect-video w-full">
                  <iframe
                    src={url}
                    class="absolute top-0 left-0 h-full w-full"
                    allow="autoplay; fullscreen"
                    allowfullscreen
                    title={`${title} — Vidéo ${index + 1}`}
                    style="border: none;"
                  />
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    ) : null
  }
</section>
